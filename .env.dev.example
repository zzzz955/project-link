# =============================================================
# Project Link dev container environment
# Copy this file to .env.dev and fill in actual values.
# NEVER commit .env.dev to git.
# Usage: docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.dev.yml up -d
#
# Port policy:
# - 20000-20099: shared auth platform
# - 20100-20199: this game stack
# =============================================================

GAME_ENV=dev
ASPNETCORE_ENVIRONMENT=Development

# ----- Compose / Containers -----
COMPOSE_PROJECT_NAME=project-link

# Dev: use 0.0.0.0 if a phone or another LAN device must call the API.
API_HOST_BIND=0.0.0.0
API_HOST_PORT=20101
API_CONTAINER_PORT=8080

POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=20132
POSTGRES_CONTAINER_HOST=db
POSTGRES_CONTAINER_PORT=5432

REDIS_CONTAINER_HOST=redis
REDIS_CONTAINER_PORT=6379

# ----- PostgreSQL -----
DB_TYPE=postgresql

POSTGRES_DB=projectlink_db
POSTGRES_USER=postgres
DB_PASSWORD=change_me
POSTGRES_PASSWORD=change_me

# Host-side tools (npm run gen:orm) connect through published ports.
DB_HOST=localhost
DB_PORT=20132

# ----- Server -----
APP_CLIENT_ID=projectlink
APP_ALLOWED_CLIENT_VERSION=1.0.0
APP_ALLOWED_PROTOCOL_VERSION=1

# ----- Auth / Security -----
# AUTH_USE_MOCK=true : game server skips platform JWT validation (platform auth not required)
# AUTH_USE_MOCK=false: game server validates JWTs via platform JWKS (requires platform stack on madalang-net)
AUTH_USE_MOCK=true
JWT_AUTHORITY=http://localhost:20001
JWT_AUDIENCE=platform-games

# ----- GitHub Integration (optional local automation) -----
GITHUB_TOKEN=
GITHUB_REPO_URL=https://github.com/madalang-games/project-link
GITHUB_DEFAULT_PROJECT=project-link
GITHUB_DEFAULT_ASSIGNEE=

# ----- gen:orm override (optional, overrides template.ini) -----
# GEN_ORM_DRY_RUN=true
