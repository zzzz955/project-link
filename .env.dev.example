# =============================================================
# Project Link dev container environment
# Copy this file to .env.dev and fill in actual values.
# NEVER commit .env.dev to git.
# Usage: docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.dev.yml up -d
#
# Port policy:
# - 20000-20099: shared auth platform
# - 20100-20199: this game stack
# =============================================================

# 변수 설명:
# GAME_ENV: 게임 스택 실행 환경(dev/prod)
# ASPNETCORE_ENVIRONMENT: ASP.NET Core 런타임 환경
# COMPOSE_PROJECT_NAME: Docker Compose 프로젝트 이름
# API_HOST_BIND: 호스트에서 API 포트를 바인딩할 IP
# API_HOST_PORT: 호스트에 공개할 API 포트
# API_CONTAINER_PORT: API 컨테이너 내부 포트
# POSTGRES_HOST_BIND: 호스트에서 PostgreSQL 포트를 바인딩할 IP
# POSTGRES_HOST_PORT: 호스트에 공개할 PostgreSQL 포트
# POSTGRES_CONTAINER_HOST: 컨테이너 네트워크에서 PostgreSQL 서비스 이름
# POSTGRES_CONTAINER_PORT: PostgreSQL 컨테이너 내부 포트
# REDIS_CONTAINER_HOST: 컨테이너 네트워크에서 Redis 서비스 이름
# REDIS_CONTAINER_PORT: Redis 컨테이너 내부 포트
# DB_TYPE: tools/gen-orm이 사용할 DB 종류
# POSTGRES_DB: PostgreSQL 데이터베이스 이름
# POSTGRES_USER: PostgreSQL 사용자 이름
# DB_PASSWORD: 호스트 도구가 DB 접속에 사용할 비밀번호
# POSTGRES_PASSWORD: PostgreSQL 컨테이너 초기 비밀번호
# DB_HOST: 호스트에서 tools가 접속할 DB 호스트
# DB_PORT: 호스트에서 tools가 접속할 DB 포트
# APP_CLIENT_ID: 게임 서버가 허용할 클라이언트 ID
# APP_ALLOWED_CLIENT_VERSION: 허용할 클라이언트 버전
# APP_ALLOWED_PROTOCOL_VERSION: 허용할 API 프로토콜 버전
# AUTH_USE_MOCK: 플랫폼 JWT 검증 대신 목 인증을 사용할지 여부
# JWT_AUTHORITY: JWT 발급자/JWKS 조회 주소
# JWT_AUDIENCE: JWT audience 값
# GITHUB_TOKEN: GitHub 자동화용 개인 액세스 토큰
# GITHUB_REPO_URL: 기본 GitHub 저장소 URL
# GITHUB_DEFAULT_PROJECT: GitHub 자동화 기본 프로젝트명
# GITHUB_DEFAULT_ASSIGNEE: GitHub 자동화 기본 담당자
# GEN_ORM_DRY_RUN: gen:orm의 DB 반영 여부를 template.ini보다 우선 제어

GAME_ENV=dev
ASPNETCORE_ENVIRONMENT=Development

# ----- Compose / Containers -----
COMPOSE_PROJECT_NAME=project-link

# Dev: use 0.0.0.0 if a phone or another LAN device must call the API.
API_HOST_BIND=0.0.0.0
API_HOST_PORT=20101
API_CONTAINER_PORT=8080

POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=20132
POSTGRES_CONTAINER_HOST=db
POSTGRES_CONTAINER_PORT=5432

REDIS_CONTAINER_HOST=redis
REDIS_CONTAINER_PORT=6379

# ----- PostgreSQL -----
DB_TYPE=postgresql

POSTGRES_DB=projectlink_db
POSTGRES_USER=postgres
DB_PASSWORD=change_me
POSTGRES_PASSWORD=change_me

# Host-side tools (npm run gen:orm) connect through published ports.
DB_HOST=localhost
DB_PORT=20132

# ----- Server -----
APP_CLIENT_ID=projectlink
APP_ALLOWED_CLIENT_VERSION=1.0.0
APP_ALLOWED_PROTOCOL_VERSION=1

# ----- Auth / Security -----
# AUTH_USE_MOCK=true : game server skips platform JWT validation (platform auth not required)
# AUTH_USE_MOCK=false: game server validates JWTs via platform JWKS (requires platform stack on madalang-net)
AUTH_USE_MOCK=true
JWT_AUTHORITY=http://localhost:20001
JWT_AUDIENCE=platform-games

# ----- GitHub Integration (optional local automation) -----
GITHUB_TOKEN=
GITHUB_REPO_URL=https://github.com/madalang-games/project-link
GITHUB_DEFAULT_PROJECT=project-link
GITHUB_DEFAULT_ASSIGNEE=

# ----- gen:orm override (optional, overrides template.ini) -----
# GEN_ORM_DRY_RUN=true
