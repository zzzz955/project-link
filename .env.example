# =============================================================
# Development Template — Environment Variables
# Copy this file to .env and fill in actual values.
# NEVER commit .env to git.
# Non-secret settings → template.ini
# =============================================================

# ----- Database -----
DB_TYPE=postgresql
# Supported: postgresql, mysql, sqlite

DB_HOST=localhost
DB_PORT=5432
DB_NAME=game_db
DB_USER=game_user
DB_PASSWORD=your_password_here

# For SQLite only (path to .db file)
# DB_FILE=server/db/game.db

# ----- Server -----
SERVER_PORT=3000
SERVER_HOST=localhost
NODE_ENV=development

# ----- Auth / Security -----
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=7d

# ----- GitHub Integration (for .claude/commands/git-*.md skills) -----
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO_URL=https://github.com/owner/repo-name
GITHUB_DEFAULT_PROJECT=
GITHUB_DEFAULT_ASSIGNEE=

# ----- gen:orm override (optional, overrides template.ini) -----
# GEN_ORM_DRY_RUN=true
