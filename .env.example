# =============================================================
# Project Link container environment
# Copy this file to .env and fill in actual values.
# NEVER commit .env to git.
# Non-secret settings belong in template.ini.
# =============================================================

# ----- Compose / Containers -----
COMPOSE_PROJECT_NAME=project-link

API_HOST_PORT=8080
API_CONTAINER_PORT=8080

POSTGRES_HOST_PORT=5432
POSTGRES_CONTAINER_HOST=db
POSTGRES_CONTAINER_PORT=5432

REDIS_HOST_PORT=6379
REDIS_CONTAINER_HOST=redis
REDIS_CONTAINER_PORT=6379

# ----- PostgreSQL -----
DB_TYPE=postgresql
# Supported: postgresql, mysql, sqlite

POSTGRES_DB=projectlink_db
POSTGRES_USER=postgres
DB_PASSWORD=change_me
POSTGRES_PASSWORD=change_me

# Host-side tools (npm run gen:orm) connect through published ports.
DB_HOST=localhost
DB_PORT=5432

# For SQLite only (path to .db file)
# DB_FILE=server/db/game.db

# ----- Server -----
NODE_ENV=development
APP_CLIENT_ID=projectlink
APP_ALLOWED_CLIENT_VERSION=1.0.0
APP_ALLOWED_PROTOCOL_VERSION=1

# ----- Auth / Security -----
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=7d
JWT_AUTHORITY=
JWT_AUDIENCE=

# ----- GitHub Integration (optional local automation) -----
GITHUB_TOKEN=
GITHUB_REPO_URL=https://github.com/zzzz955/project-link
GITHUB_DEFAULT_PROJECT=project-link
GITHUB_DEFAULT_ASSIGNEE=zzzz955

# ----- gen:orm override (optional, overrides template.ini) -----
# GEN_ORM_DRY_RUN=true
