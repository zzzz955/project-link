# Copy to .env.prod and fill real production values.
# Usage: docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.prod.yml up -d

COMPOSE_PROJECT_NAME=project-link
GAME_ENV=prod
ASPNETCORE_ENVIRONMENT=Production

API_BIND_ADDRESS=127.0.0.1
API_PUBLISHED_PORT=20101
API_CONTAINER_PORT=8080

DB_BIND_ADDRESS=127.0.0.1
DB_PUBLISHED_PORT=20132
DB_CONTAINER_PORT=3306
DB_NAME=projectlink_db
DB_USER=projectlink
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DB_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD

REDIS_CONTAINER_PORT=6379

APP_CLIENT_ID=projectlink
APP_ALLOWED_CLIENT_VERSION=1.0.0
APP_ALLOWED_PROTOCOL_VERSION=1

AUTH_USE_MOCK=false
JWT_AUTHORITY=http://platform-auth:8080
JWT_AUDIENCE=platform-games
