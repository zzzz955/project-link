{
  "database": "projectlink_db",
  "tables": [
    {
      "name": "sessions",
      "columns": [
        { "name": "id",         "type": "int64",      "constraints": ["PK","AUTO","NN"] },
        { "name": "user_id",    "type": "string(36)", "constraints": ["NN"] },
        { "name": "session_id", "type": "string(36)", "constraints": ["NN","UQ"] },
        { "name": "created_at", "type": "datetime",   "constraints": ["NN"] },
        { "name": "expires_at", "type": "datetime",   "constraints": ["NN"] },
        { "name": "active",     "type": "bool",       "constraints": ["NN"], "default": "true" }
      ],
      "indexes": [{ "name": "idx_sessions_user_id", "columns": ["user_id"] }]
    },
    {
      "name": "stage_progress",
      "comment": "PK is composite (user_id, stage_id) — best stars per stage",
      "columns": [
        { "name": "user_id",    "type": "string(36)", "constraints": ["PK","NN"] },
        { "name": "stage_id",   "type": "int32",      "constraints": ["PK","NN"] },
        { "name": "stars",      "type": "int32",      "constraints": ["NN"] },
        { "name": "cleared_at", "type": "datetime",   "constraints": ["NN"] }
      ]
    },
    {
      "name": "currency_logs",
      "comment": "Append-only audit log — never UPDATE or DELETE",
      "columns": [
        { "name": "id",             "type": "int64",      "constraints": ["PK","AUTO","NN"] },
        { "name": "user_id",        "type": "string(36)", "constraints": ["NN"] },
        { "name": "transaction_id", "type": "string(36)", "constraints": ["NN"] },
        { "name": "currency_type",  "type": "string(32)", "constraints": ["NN"] },
        { "name": "delta",          "type": "int64",      "constraints": ["NN"] },
        { "name": "balance_before", "type": "int64",      "constraints": ["NN"] },
        { "name": "balance_after",  "type": "int64",      "constraints": ["NN"] },
        { "name": "reason",         "type": "string",     "constraints": ["NN"] },
        { "name": "correlation_id", "type": "string(36)", "constraints": ["NN"] },
        { "name": "created_at",     "type": "datetime",   "constraints": ["NN"] }
      ],
      "indexes": [{ "name": "idx_currency_logs_user_id", "columns": ["user_id"] }]
    },
    {
      "name": "stamina_state",
      "comment": "Lazy-evaluated stamina — current value at time of last write",
      "columns": [
        { "name": "user_id",           "type": "string(36)", "constraints": ["PK","NN"] },
        { "name": "current",           "type": "int8",       "constraints": ["NN"] },
        { "name": "last_recharged_at", "type": "datetime",   "constraints": ["NN"] }
      ]
    },
    {
      "name": "user_currency",
      "comment": "Current soft currency balance per user",
      "columns": [
        { "name": "user_id",     "type": "string(36)", "constraints": ["PK","NN"] },
        { "name": "soft_amount", "type": "int64",      "constraints": ["NN"], "default": "0" }
      ]
    },
    {
      "name": "inventory",
      "comment": "PK is composite (user_id, item_id)",
      "columns": [
        { "name": "user_id",  "type": "string(36)", "constraints": ["PK","NN"] },
        { "name": "item_id",  "type": "int32",      "constraints": ["PK","NN"] },
        { "name": "quantity", "type": "int32",      "constraints": ["NN"], "default": "0" }
      ]
    },
    {
      "name": "stage_best_records",
      "comment": "PK is composite (user_id, stage_id) — best clear time + score per stage for ranking",
      "columns": [
        { "name": "user_id",          "type": "string(36)", "constraints": ["PK","NN"] },
        { "name": "stage_id",         "type": "int32",      "constraints": ["PK","NN"] },
        { "name": "best_clear_time_ms", "type": "int64",    "constraints": ["NN"] },
        { "name": "best_score",       "type": "int32",      "constraints": ["NN"] },
        { "name": "cleared_at",       "type": "datetime",   "constraints": ["NN"] }
      ]
    },
    {
      "name": "user_ranking_cache",
      "comment": "Aggregate ranking snapshot — rebuilt from stage_best_records on Redis cold start",
      "columns": [
        { "name": "user_id",        "type": "string(36)", "constraints": ["PK","NN"] },
        { "name": "total_score",    "type": "int64",      "constraints": ["NN"], "default": "0" },
        { "name": "stages_cleared", "type": "int32",      "constraints": ["NN"], "default": "0" },
        { "name": "updated_at",     "type": "datetime",   "constraints": ["NN"] }
      ]
    },
    {
      "name": "user_profiles",
      "comment": "Game server user cache — populated on first login from JWT claims",
      "columns": [
        { "name": "user_id",            "type": "string(36)", "constraints": ["PK","NN"] },
        { "name": "display_name",       "type": "string(64)", "constraints": ["NN"] },
        { "name": "avatar_id",          "type": "int32",      "constraints": ["NN"], "default": "1" },
        { "name": "account_created_at",     "type": "datetime", "constraints": ["NN"] },
        { "name": "last_login_at",           "type": "datetime", "constraints": ["NN"] },
        { "name": "max_cleared_stage_id",    "type": "int32",    "constraints": ["NN"], "default": "0" }
      ]
    },
    {
      "name": "streak_challenge_user_state",
      "comment": "One row per (user, event, cycle). Lazy Reset updates event_status on expiry.",
      "columns": [
        { "name": "user_id",               "type": "string(36)", "constraints": ["PK","NN"] },
        { "name": "event_id",              "type": "int32",      "constraints": ["PK","NN"] },
        { "name": "cycle_id",              "type": "string(36)", "constraints": ["PK","NN"] },
        { "name": "event_version",         "type": "int32",      "constraints": ["NN"] },
        { "name": "event_status",          "type": "string(32)", "constraints": ["NN"] },
        { "name": "activated_at",          "type": "datetime",   "constraints": ["NN"] },
        { "name": "expires_at",            "type": "datetime",   "constraints": ["NN"] },
        { "name": "current_level",         "type": "int32",      "constraints": ["NN"], "default": "0" },
        { "name": "last_counted_stage_id", "type": "int32",      "constraints": ["NN"], "default": "0" },
        { "name": "created_at",            "type": "datetime",   "constraints": ["NN"] },
        { "name": "updated_at",            "type": "datetime",   "constraints": ["NN"] }
      ],
      "indexes": [
        { "name": "idx_streak_state_user_event", "columns": ["user_id","event_id"] }
      ]
    },
    {
      "name": "streak_challenge_user_level_state",
      "comment": "Per-level progress for each user cycle. Reset only resets current_count, not completed levels.",
      "columns": [
        { "name": "user_id",          "type": "string(36)", "constraints": ["PK","NN"] },
        { "name": "event_id",         "type": "int32",      "constraints": ["PK","NN"] },
        { "name": "cycle_id",         "type": "string(36)", "constraints": ["PK","NN"] },
        { "name": "level_index",      "type": "int32",      "constraints": ["PK","NN"] },
        { "name": "level_status",     "type": "string(32)", "constraints": ["NN"] },
        { "name": "required_count",   "type": "int32",      "constraints": ["NN"] },
        { "name": "current_count",    "type": "int32",      "constraints": ["NN"], "default": "0" },
        { "name": "started_at",       "type": "datetime",   "constraints": [] },
        { "name": "completed_at",     "type": "datetime",   "constraints": [] },
        { "name": "reward_state",     "type": "string(32)", "constraints": ["NN"], "default": "'NONE'" },
        { "name": "reward_claimed_at","type": "datetime",   "constraints": [] },
        { "name": "updated_at",       "type": "datetime",   "constraints": ["NN"] }
      ],
      "indexes": [
        { "name": "idx_streak_level_user_event", "columns": ["user_id","event_id","cycle_id"] }
      ]
    },
    {
      "name": "streak_challenge_reward_claim_history",
      "comment": "Append-only idempotency log for reward claims. correlation_id ensures duplicate-safe grants.",
      "columns": [
        { "name": "id",                   "type": "int64",      "constraints": ["PK","AUTO","NN"] },
        { "name": "user_id",              "type": "string(36)", "constraints": ["NN"] },
        { "name": "event_id",             "type": "int32",      "constraints": ["NN"] },
        { "name": "cycle_id",             "type": "string(36)", "constraints": ["NN"] },
        { "name": "level_index",          "type": "int32",      "constraints": ["NN"] },
        { "name": "reward_group_id",      "type": "int32",      "constraints": ["NN"] },
        { "name": "reward_group_version", "type": "int32",      "constraints": ["NN"] },
        { "name": "reward_multiplier",    "type": "int32",      "constraints": ["NN"], "default": "1" },
        { "name": "claim_status",         "type": "string(32)", "constraints": ["NN"] },
        { "name": "correlation_id",       "type": "string(36)", "constraints": ["NN","UQ"] },
        { "name": "created_at",           "type": "datetime",   "constraints": ["NN"] },
        { "name": "updated_at",           "type": "datetime",   "constraints": ["NN"] }
      ],
      "indexes": [
        { "name": "idx_streak_claim_user_cycle", "columns": ["user_id","cycle_id","level_index"] }
      ]
    },
    {
      "name": "streak_challenge_ad_reward_history",
      "comment": "Append-only log of rewarded-ad attempts for streak challenge.",
      "columns": [
        { "name": "id",               "type": "int64",      "constraints": ["PK","AUTO","NN"] },
        { "name": "user_id",          "type": "string(36)", "constraints": ["NN"] },
        { "name": "event_id",         "type": "int32",      "constraints": ["NN"] },
        { "name": "cycle_id",         "type": "string(36)", "constraints": ["NN"] },
        { "name": "level_index",      "type": "int32",      "constraints": ["NN"] },
        { "name": "ad_placement_id",  "type": "string(64)", "constraints": ["NN"] },
        { "name": "ad_result",        "type": "string(32)", "constraints": ["NN"] },
        { "name": "multiplier_applied","type": "bool",      "constraints": ["NN"], "default": "false" },
        { "name": "created_at",       "type": "datetime",   "constraints": ["NN"] }
      ],
      "indexes": [
        { "name": "idx_streak_ad_user_cycle", "columns": ["user_id","cycle_id","level_index"] }
      ]
    },
    {
      "name": "player_settings",
      "comment": "Server-synced player preferences — authoritative if client-server sync is enabled",
      "columns": [
        { "name": "user_id",               "type": "string(36)", "constraints": ["PK","NN"] },
        { "name": "bgm_enabled",           "type": "bool",       "constraints": ["NN"], "default": "true" },
        { "name": "sfx_enabled",           "type": "bool",       "constraints": ["NN"], "default": "true" },
        { "name": "haptics_enabled",       "type": "bool",       "constraints": ["NN"], "default": "true" },
        { "name": "notifications_enabled", "type": "bool",       "constraints": ["NN"], "default": "true" },
        { "name": "language",              "type": "string(8)",  "constraints": ["NN"], "default": "'EN'" },
        { "name": "updated_at",            "type": "datetime",   "constraints": ["NN"] }
      ]
    },
    {
      "name": "action_logs",
      "comment": "Append-only general action audit log — never UPDATE or DELETE",
      "columns": [
        { "name": "id",             "type": "int64",      "constraints": ["PK","AUTO","NN"] },
        { "name": "user_id",        "type": "string(36)", "constraints": ["NN"] },
        { "name": "action_type",    "type": "string(64)", "constraints": ["NN"] },
        { "name": "payload",        "type": "json" },
        { "name": "correlation_id", "type": "string(36)", "constraints": ["NN"] },
        { "name": "created_at",     "type": "datetime",   "constraints": ["NN"] }
      ],
      "indexes": [
        { "name": "idx_action_logs_user_id",    "columns": ["user_id"] },
        { "name": "idx_action_logs_action_type","columns": ["action_type"] }
      ]
    }
  ]
}
