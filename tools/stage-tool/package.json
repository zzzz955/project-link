{
  "name": "project-link-stage-tool",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "start": "node dist/server/index.js",
    "dev": "concurrently \"ts-node src/server/index.ts\" \"vite --host 127.0.0.1\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "game-development-template": "file:../..",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^9.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
